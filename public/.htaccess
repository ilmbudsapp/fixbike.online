# fixbike.online — static sitemap/robots; no SPA rewrite; no compression on XML
Options -MultiViews

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  RewriteRule ^sitemap\.xml$ - [END]
  RewriteRule ^robots\.txt$ - [END]
  RewriteRule ^feed\.xml$ - [END]
  RewriteRule ^indexnow-key\.txt$ - [END]
  RewriteRule ^manifest\.json$ - [END]

  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  RewriteRule ^ index.html [L]
</IfModule>

<IfModule mod_authz_core.c>
  <FilesMatch "^(sitemap\.xml|robots\.txt|feed\.xml)$">
    Require all granted
  </FilesMatch>
</IfModule>

<IfModule mod_mime.c>
  <Files "sitemap.xml">
    ForceType application/xml
  </Files>
  <Files "feed.xml">
    ForceType application/xml
  </Files>
</IfModule>

<IfModule mod_deflate.c>
  <FilesMatch "^(sitemap\.xml|feed\.xml)$">
    SetEnv no-gzip 1
    SetEnv dont-vary 1
  </FilesMatch>
</IfModule>

<IfModule mod_brotli.c>
  <FilesMatch "^(sitemap\.xml|feed\.xml)$">
    SetEnv no-brotli 1
  </FilesMatch>
</IfModule>

<IfModule mod_headers.c>
  <Files "sitemap.xml">
    Header always unset Content-Encoding
    Header always unset X-Robots-Tag
    Header always set Content-Type "application/xml; charset=UTF-8"
  </Files>
  <Files "robots.txt">
    Header always unset X-Robots-Tag
    Header always set Content-Type "text/plain; charset=UTF-8"
  </Files>
  <Files "feed.xml">
    Header always unset Content-Encoding
    Header always unset X-Robots-Tag
    Header always set Content-Type "application/xml; charset=UTF-8"
  </Files>
</IfModule>