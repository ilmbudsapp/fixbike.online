# fixbike.online — direct bypass for crawler files; SPA fallback only after
Options -MultiViews

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  RewriteRule ^sitemap\.xml$ - [L,NC]
  RewriteRule ^robots\.txt$ - [L,NC]
  RewriteRule ^feed\.xml$ - [L,NC]
  RewriteRule ^indexnow-key\.txt$ - [L,NC]
  RewriteRule ^manifest\.json$ - [L,NC]

  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  RewriteRule ^ index.html [L]
</IfModule>

<IfModule mod_authz_core.c>
  <FilesMatch "^(sitemap\.xml|robots\.txt|feed\.xml)$">
    Require all granted
  </FilesMatch>
</IfModule>

<IfModule mod_mime.c>
  <Files "sitemap.xml">
    ForceType application/xml
  </Files>
  <Files "feed.xml">
    ForceType application/xml
  </Files>
</IfModule>

<IfModule mod_deflate.c>
  <FilesMatch "^(sitemap\.xml|feed\.xml)$">
    SetEnv no-gzip 1
    SetEnv dont-vary 1
  </FilesMatch>
</IfModule>

<IfModule mod_brotli.c>
  <FilesMatch "^(sitemap\.xml|feed\.xml)$">
    SetEnv no-brotli 1
  </FilesMatch>
</IfModule>

<IfModule mod_headers.c>
  <Files "sitemap.xml">
    Header always unset Content-Encoding
    Header always unset X-Robots-Tag
    Header always set Content-Type "application/xml; charset=UTF-8"
  </Files>
  <Files "robots.txt">
    Header always unset X-Robots-Tag
    Header always set Content-Type "text/plain; charset=UTF-8"
  </Files>
  <Files "feed.xml">
    Header always unset Content-Encoding
    Header always unset X-Robots-Tag
    Header always set Content-Type "application/xml; charset=UTF-8"
  </Files>
</IfModule>

<IfModule mod_headers.c>
  <Files "index.html">
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    Header always set Permissions-Policy "camera=(), microphone=(), geolocation=(), payment=()"
    Header always set Content-Security-Policy "default-src 'self'; img-src 'self' data: https: https://img.youtube.com https://i.ytimg.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; script-src 'self' 'unsafe-inline'; frame-src https://maps.google.com https://www.google.com https://www.youtube.com https://www.youtube-nocookie.com; connect-src 'self' https://api.web3forms.com; upgrade-insecure-requests"
  </Files>
</IfModule>